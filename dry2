-- FPS BOOST + SKY + UI + WATERMARK RGB SINCRONIZADO
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- =========================
-- 🔧 OTIMIZAÇÃO GRÁFICA
-- =========================

settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

for _, v in pairs(Lighting:GetChildren()) do
	if v:IsA("BlurEffect")
	or v:IsA("SunRaysEffect")
	or v:IsA("BloomEffect")
	or v:IsA("DepthOfFieldEffect")
	or v:IsA("ColorCorrectionEffect") then
		v:Destroy()
	end
end

Lighting.GlobalShadows = false
Lighting.FogEnd = 1000000
Lighting.Brightness = 1
Lighting.EnvironmentDiffuseScale = 0
Lighting.EnvironmentSpecularScale = 0

for _, obj in pairs(workspace:GetDescendants()) do
	if obj:IsA("ParticleEmitter")
	or obj:IsA("Trail")
	or obj:IsA("Smoke")
	or obj:IsA("Fire")
	or obj:IsA("Sparkles") then
		obj.Enabled = false
	end

	if obj:IsA("Decal") or obj:IsA("Texture") then
		obj:Destroy()
	end

	if obj:IsA("BasePart") then
		obj.Material = Enum.Material.Plastic
		obj.Reflectance = 0
	end
end

-- =========================
-- 🌌 SKY MODIFICADO
-- =========================

for _, v in pairs(Lighting:GetChildren()) do
	if v:IsA("Sky") then
		v:Destroy()
	end
end

local sky = Instance.new("Sky")
sky.SkyboxBk = "rbxassetid://1012890"
sky.SkyboxDn = "rbxassetid://1012890"
sky.SkyboxFt = "rbxassetid://1012890"
sky.SkyboxLf = "rbxassetid://1012890"
sky.SkyboxRt = "rbxassetid://1012890"
sky.SkyboxUp = "rbxassetid://1012890"
sky.Parent = Lighting

-- =========================
-- 📊 CONTADOR DE FPS
-- =========================

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "PerformanceUI"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local fpsLabel = Instance.new("TextLabel")
fpsLabel.Size = UDim2.new(0, 120, 0, 30)
fpsLabel.Position = UDim2.new(0, 10, 0, 10)
fpsLabel.BackgroundTransparency = 1
fpsLabel.TextColor3 = Color3.new(1,1,1)
fpsLabel.TextScaled = true
fpsLabel.Font = Enum.Font.GothamBold
fpsLabel.Text = "FPS: 0"
fpsLabel.Parent = screenGui

local frames = 0
local lastTime = tick()

RunService.RenderStepped:Connect(function()
	frames += 1
	if tick() - lastTime >= 1 then
		fpsLabel.Text = "FPS: " .. frames
		frames = 0
		lastTime = tick()
	end
end)

-- =========================
-- 🏷️ WATERMARK RGB SINCRONIZADO + ONDA
-- =========================

local watermarkText = "Rebelde X Dryx"
local letters = {}

local baseX = 1
local baseOffsetX = -20
local baseY = 0
local baseOffsetY = 10

local currentOffset = 0

for i = 1, #watermarkText do
	local char = string.sub(watermarkText, i, i)

	local letter = Instance.new("TextLabel")
	letter.Size = UDim2.new(0, 0, 0, 40)
	letter.AutomaticSize = Enum.AutomaticSize.X
	letter.Position = UDim2.new(baseX, baseOffsetX - currentOffset, baseY, baseOffsetY)
	letter.AnchorPoint = Vector2.new(1, 0)
	letter.BackgroundTransparency = 1
	letter.Text = char
	letter.TextScaled = true
	letter.Font = Enum.Font.GothamBold
	letter.Parent = screenGui
	
	local stroke = Instance.new("UIStroke")
	stroke.Thickness = 2
	stroke.Color = Color3.fromRGB(0,0,0)
	stroke.Parent = letter
	
	table.insert(letters, letter)

	task.wait()
	currentOffset += letter.AbsoluteSize.X
end

local amplitude = 6
local waveSpeed = 4
local rgbSpeed = 2

RunService.RenderStepped:Connect(function()
	local time = tick()

	-- RGB sincronizado
	local r = math.sin(time * rgbSpeed) * 127 + 128
	local g = math.sin(time * rgbSpeed + 2) * 127 + 128
	local b = math.sin(time * rgbSpeed + 4) * 127 + 128
	local rgbColor = Color3.fromRGB(r, g, b)

	local offsetX = 0

	for i, letter in ipairs(letters) do
		
		local waveOffset = math.sin(time * waveSpeed + i * 0.5) * amplitude
		
		letter.Position = UDim2.new(
			baseX,
			baseOffsetX - offsetX,
			baseY,
			baseOffsetY + waveOffset
		)

		letter.TextColor3 = rgbColor
		
		offsetX += letter.AbsoluteSize.X
	end
end)

print("Modo FPS Boost + Sky + FPS Counter + Watermark RGB sincronizado ativado!")
