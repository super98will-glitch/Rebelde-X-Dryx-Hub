end)

-- Animação de entrada
TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0,300,0,150)}):Play()

-- =========================
-- FUNÇÃO DE ATIVAÇÃO DO SCRIPT
-- =========================
local function activateScript()
	screenGui:Destroy()

	-- 🔧 FORÇAR LOW POLY
	settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
	for _, v in pairs(Lighting:GetChildren()) do
		if v:IsA("BlurEffect")
		or v:IsA("SunRaysEffect")
		or v:IsA("BloomEffect")
		or v:IsA("DepthOfFieldEffect")
		or v:IsA("ColorCorrectionEffect")
		or v:IsA("Atmosphere") then
			v:Destroy()
		end
	end
	Lighting.GlobalShadows = false
	Lighting.FogEnd = 1000000

	-- 🌌 SKY BLUE PLANET
	for _, v in pairs(Lighting:GetChildren()) do
		if v:IsA("Sky") then
			v:Destroy()
		end
	end
	local sky = Instance.new("Sky")
	-- Sky Blue Planet ID (roblox default)
	local bluePlanetId = "rbxassetid://6062450459"
	sky.SkyboxBk = bluePlanetId
	sky.SkyboxDn = bluePlanetId
	sky.SkyboxFt = bluePlanetId
	sky.SkyboxLf = bluePlanetId
	sky.SkyboxRt = bluePlanetId
	sky.SkyboxUp = bluePlanetId
	sky.Parent = Lighting

	-- 📊 FPS COUNTER
	local fpsLabel = Instance.new("TextLabel")
	fpsLabel.Size = UDim2.new(0,120,0,30)
	fpsLabel.Position = UDim2.new(0,10,0,10)
	fpsLabel.BackgroundTransparency = 1
	fpsLabel.TextColor3 = Color3.new(1,1,1)
	fpsLabel.TextScaled = true
	fpsLabel.Font = Enum.Font.GothamBold
	fpsLabel.Text = "FPS: 0"
	fpsLabel.Parent = player.PlayerGui

	local frames = 0
	local lastTime = tick()
	RunService.RenderStepped:Connect(function()
		frames += 1
		if tick()-lastTime >= 1 then
			fpsLabel.Text = "FPS: "..frames
			frames = 0
			lastTime = tick()
		end
	end)

	-- 🏷️ WATERMARK RGB ULTRA COM GLOW
	local watermarkText = "Rebelde X Dryx"
	local letters = {}
	local startX,startY,startOffsetY,spacing = 0.75,0,10,18

	for i=1,#watermarkText do
		local char = string.sub(watermarkText,i,i)
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(0,20,0,40)
		label.Position = UDim2.new(startX,(i-1)*spacing,startY,startOffsetY)
		label.BackgroundTransparency = 1
		label.Text = char
		label.TextScaled = true
		label.Font = Enum.Font.GothamBold
		label.Parent = player.PlayerGui

		local stroke = Instance.new("UIStroke")
		stroke.Thickness = 2
		stroke.Color = Color3.fromRGB(0,0,0)
		stroke.Parent = label

		local glow = Instance.new("UIStroke")
		glow.Thickness = 4
		glow.Color = Color3.fromRGB(0,255,255)
		glow.Parent = label

		table.insert(letters,{label=label,glow=glow})
	end

	local amplitude,waveSpeed,rgbSpeed,glowSpeed=6,4,2,5
	RunService.RenderStepped:Connect(function()
		local time = tick()
		local r = math.sin(time*rgbSpeed)*127+128
		local g = math.sin(time*rgbSpeed+2)*127+128
		local b = math.sin(time*rgbSpeed+4)*127+128
		local rgbColor = Color3.fromRGB(r,g,b)
		local glowIntensity = (math.sin(time*glowSpeed)*0.5+0.5)*4+2

		for i,obj in ipairs(letters) do
			local waveOffset = math.sin(time*waveSpeed + i*0.5)*amplitude
			obj.label.Position = UDim2.new(startX,(i-1)*spacing,startY,startOffsetY+waveOffset)
			obj.label.TextColor3 = rgbColor
			obj.glow.Color = rgbColor
			obj.glow.Thickness = glowIntensity
		end
	end)

	print("SCRIPT ATIVADO COM SKY BLUE PLANET, LOW POLY, FPS E WATERMARK ULTRA!")
end

-- =========================
-- BOTÃO CONFIRMAR
-- =========================
button.MouseButton1Click:Connect(function()
	if textbox.Text == correctPassword then
		activateScript()
	else
		textbox.Text = ""
		textbox.PlaceholderText = "Senha incorreta!"
	end
end)
