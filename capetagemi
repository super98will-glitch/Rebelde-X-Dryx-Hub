-- ================= SISTEMA DE ABAS =================
local tabs = {}
local tabButtons = {}

local function createTab(name, isFirst)
	-- Criar Botão na Sidebar
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0.9, 0, 0, 35)
	btn.Position = UDim2.new(0.05, 0, 0, 10 + (#tabButtons * 40))
	btn.Text = name
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 14
	btn.BackgroundColor3 = isFirst and Color3.fromRGB(60, 120, 255) or Color3.fromRGB(30, 30, 35)
	btn.TextColor3 = Color3.new(1, 1, 1)
	btn.Parent = sidebar
	style(btn)
	table.insert(tabButtons, btn)

	-- Criar Frame da Aba
	local frame = Instance.new("ScrollingFrame")
	frame.Size = UDim2.new(1, 0, 1, 0)
	frame.BackgroundTransparency = 1
	frame.ScrollBarThickness = 4
	frame.Visible = isFirst
	frame.Parent = contentArea
	
	local layout = Instance.new("UIListLayout")
	layout.Padding = UDim.new(0, 10)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent = frame

	tabs[btn] = frame

	-- Lógica de clique na Aba
	btn.MouseButton1Click:Connect(function()
		for b, f in pairs(tabs) do
			f.Visible = (b == btn)
			b.BackgroundColor3 = (b == btn) and Color3.fromRGB(60, 120, 255) or Color3.fromRGB(30, 30, 35)
		end
	end)

	return frame
end

