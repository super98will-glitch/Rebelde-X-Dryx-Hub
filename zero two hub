local function applyDesign(obj, radius, stroke)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius or 8)
	corner.Parent = obj
	if stroke then
		local s = Instance.new("UIStroke")
		s.Color = Theme.Accent
		s.Thickness = 1.5
		s.Transparency = 0.3
		s.Parent = obj
	end
end

