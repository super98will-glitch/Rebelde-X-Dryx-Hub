--[[ ADD ESP: Configurações e variáveis do ESP ]]
-- Variáveis de controle
local espEnabled = false
local espBox = true
local espName = true
local espHealth = true

-- Tabela para armazenar os objetos Drawing de cada jogador
local espObjects = {}
local camera = workspace.CurrentCamera

-- Função para criar objetos Drawing para um jogador
local function createESP(player)
	local drawingTable = {
		Box = Drawing.new("Square"),
		Name = Drawing.new("Text"),
		HealthBar = Drawing.new("Square"),
		HealthText = Drawing.new("Text")
	}
	
	-- Configurações iniciais
	drawingTable.Box.Thickness = 1
	drawingTable.Box.Filled = false
	drawingTable.Box.Color = Color3.new(1, 1, 1)
	
	drawingTable.Name.Size = 13
	drawingTable.Name.Center = true
	drawingTable.Name.Outline = true
	drawingTable.Name.Color = Color3.new(1, 1, 1)
	
	drawingTable.HealthBar.Thickness = 0
	drawingTable.HealthBar.Filled = true
	drawingTable.HealthBar.Color = Color3.new(0, 1, 0)
	
	drawingTable.HealthText.Size = 12
	drawingTable.HealthText.Center = true
	drawingTable.HealthText.Outline = true
	drawingTable.HealthText.Color = Color3.new(1, 1, 1)
	
	espObjects[player] = drawingTable
end

-- Função para atualizar o ESP de um jogador
local function updateESPForPlayer(plr)
	if not espEnabled then return end
	
	local character = plr.Character
	if not character then
		if espObjects[plr] then
			for _, obj in pairs(espObjects[plr]) do
				obj.Visible = false
			end
		end
		return
	end
	
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
	
	if not humanoid or not rootPart then
		if espObjects[plr] then
			for _, obj in pairs(espObjects[plr]) do
				obj.Visible = false
			end
		end
		return
	end
	
	-- Posição da cabeça e dos pés
	local head = character:FindFirstChild("Head")
	local headPos = head and head.Position or rootPart.Position + Vector3.new(0, 2, 0)
	local footPos = rootPart.Position - Vector3.new(0, 2, 0)
	
	-- Converter para tela
	local headScreen, onScreenHead = camera:WorldToViewportPoint(headPos)
	local footScreen, onScreenFoot = camera:WorldToViewportPoint(footPos)
	
	if not (onScreenHead or onScreenFoot) then
		if espObjects[plr] then
			for _, obj in pairs(espObjects[plr]) do
				obj.Visible = false
			end
		end
		return
	end
	
	-- Calcular dimensões da caixa
	local yTop = headScreen.Y
	local yBottom = footScreen.Y
	local height = yBottom - yTop
	local width = height * 0.6
	local xCenter = headScreen.X
	local xLeft = xCenter - width/2
	
	-- Cor baseada no time (se houver)
	local boxColor = (plr.TeamColor == player.TeamColor) and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
	
	local esp = espObjects[plr]
	if not esp then return end
	
	-- Caixa
	if espBox then
		esp.Box.Visible = true
		esp.Box.Color = boxColor
		esp.Box.Position = Vector2.new(xLeft, yTop)
		esp.Box.Size = Vector2.new(width, height)
	else
		esp.Box.Visible = false
	end
	
	-- Nome
	if espName then
		esp.Name.Visible = true
		esp.Name.Text = plr.Name
		esp.Name.Position = Vector2.new(xCenter, yTop - 16)
		esp.Name.Color = boxColor
	else
		esp.Name.Visible = false
	end
	
	-- Barra de vida
	if espHealth and humanoid then
		local healthPercent = humanoid.Health / humanoid.MaxHealth
		local barWidth = width
		local barHeight = 4
		local barY = yTop - 6
		
		esp.HealthBar.Visible = true
		esp.HealthBar.Color = Color3.new(1 - healthPercent, healthPercent, 0)
		esp.HealthBar.Position = Vector2.new(xLeft, barY)
		esp.HealthBar.Size = Vector2.new(barWidth * healthPercent, barHeight)
		
		esp.HealthText.Visible = true
		esp.HealthText.Text = string.format("%.0f/%.0f", humanoid.Health, humanoid.MaxHealth)
		esp.HealthText.Position = Vector2.new(xCenter, barY - 14)
		esp.HealthText.Color = Color3.new(1, 1, 1)
	else
		esp.HealthBar.Visible = false
		esp.HealthText.Visible = false
	end
end

-- Loop principal de atualização
local espConnection
local function startESP()
	if espConnection then espConnection:Disconnect() end
	espConnection = RunService.RenderStepped:Connect(function()
		if not espEnabled then return end
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= player then
				updateESPForPlayer(plr)
			end
		end
	end)
end

local function stopESP()
	if espConnection then
		espConnection:Disconnect()
		espConnection = nil
	end
	-- Esconder todos os objetos
	for plr, objs in pairs(espObjects) do
		for _, obj in pairs(objs) do
			obj.Visible = false
		end
	end
end

-- Criar ESP para jogadores existentes
Players.PlayerAdded:Connect(function(plr)
	if plr ~= player then
		createESP(plr)
	end
end)

Players.PlayerRemoving:Connect(function(plr)
	if espObjects[plr] then
		for _, obj in pairs(espObjects[plr]) do
			obj:Remove()
		end
		espObjects[plr] = nil
	end
end)

-- Inicializar para jogadores atuais
for _, plr in ipairs(Players:GetPlayers()) do
	if plr ~= player then
		createESP(plr)
	end
end

-- Criar botões de controle na aba ESP
local function createToggle(text, varName, parent)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -10, 0, 40)
	btn.BackgroundColor3 = Theme.Button
	btn.Text = text .. ": " .. (getfenv()[varName] and "ON" or "OFF")
	btn.Font = Enum.Font.Gotham
	btn.TextColor3 = Theme.Text
	btn.Parent = parent
	applyDesign(btn, 8)
	
	btn.MouseButton1Click:Connect(function()
		getfenv()[varName] = not getfenv()[varName]
		btn.Text = text .. ": " .. (getfenv()[varName] and "ON" or "OFF")
		btn.BackgroundColor3 = getfenv()[varName] and Color3.fromRGB(40, 60, 40) or Theme.Button
	end)
end

