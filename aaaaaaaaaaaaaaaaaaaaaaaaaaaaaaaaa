-- ================= FUNÇÕES PERFORMANCE =================
local function optimize()
	Lighting.GlobalShadows = false
	for _, v in pairs(Workspace:GetDescendants()) do
		if v:IsA("BasePart") and not v:IsDescendantOf(player.Character) then
			v.Material = Enum.Material.SmoothPlastic
			v.CastShadow = false
		end
		if v:IsA("ParticleEmitter") or v:IsA("Trail") then v.Enabled = false end
	end
end

local function removeObjects()
	for _, obj in pairs(Workspace:GetDescendants()) do
		local name = obj.Name:lower()
		if name:find("tree") or name:find("rock") or name:find("bush") then
			obj:Destroy()
		end
	end
end

local function createPerfButton(text, func, parent)
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(1, -10, 0, 45)
	b.BackgroundColor3 = Theme.Button
	b.Text = text
	b.Font = Enum.Font.GothamSemibold
	b.TextColor3 = Theme.Text
	b.Parent = parent
	applyDesign(b, 8, Theme.Accent)
	
	b.MouseButton1Click:Connect(function()
		func()
		b.Text = text .. " ATIVADO ✓"
		b.BackgroundColor3 = Color3.fromRGB(40, 60, 40)
	end)
end

createPerfButton("ATIVAR ULTRA LOW POLY", optimize, tabPerf)
createPerfButton("REMOVER ÁRVORES E PEDRAS", removeObjects, tabPerf)

-- ================= FUNÇÕES SKY =================
local function applySky(id)
	for _, old in pairs(Lighting:GetChildren()) do if old:IsA("Sky") then old:Destroy() end end
	local s = Instance.new("Sky")
	s.SkyboxBk = id s.SkyboxDn = id s.SkyboxFt = id
	s.SkyboxLf = id s.SkyboxRt = id s.SkyboxUp = id
	s.Parent = Lighting
end

