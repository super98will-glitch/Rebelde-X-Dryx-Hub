	if fovCircle then fovCircle:Destroy() end
	
	fovCircle = Instance.new("Frame")
	fovCircle.Name = "FOVCircle"
	fovCircle.Size = UDim2.new(0, fovSize * 2, 0, fovSize * 2)
	fovCircle.Position = UDim2.new(0.5, -fovSize, 0.5, -fovSize)
	fovCircle.BackgroundTransparency = 1
	fovCircle.BorderSizePixel = 0
	fovCircle.Parent = gui
	fovCircle.Visible = false
	
	local circle = Instance.new("ImageLabel")
	circle.Size = UDim2.new(1, 0, 1, 0)
	circle.BackgroundTransparency = 1
	circle.Image = "rbxassetid://4587018687"
	circle.ImageColor3 = Color3.fromRGB(60, 120, 255)
	circle.ImageTransparency = 0.6
	circle.Parent = fovCircle
end

local function getClosestTarget()
	local character = player.Character
	if not character then return nil end
	
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return nil end
	
	local closestTarget = nil
	local closestDistance = fovSize
	
	for _, otherPlayer in ipairs(Players:GetPlayers()) do
		if otherPlayer ~= player then
			local otherChar = otherPlayer.Character
			if otherChar then
				local otherRoot = otherChar:FindFirstChild("HumanoidRootPart")
				local otherHumanoid = otherChar:FindFirstChildOfClass("Humanoid")
				
				if otherRoot and otherHumanoid and otherHumanoid.Health > 0 then
					local screenPoint, onScreen = camera:WorldToViewportPoint(otherRoot.Position)
					
					if onScreen then
						local center = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
						local targetPos = Vector2.new(screenPoint.X, screenPoint.Y)
						local distance = (targetPos - center).Magnitude
						
						if distance < closestDistance then
							closestDistance = distance
							closestTarget = otherRoot
						end
					end
				end
			end
		end
	end
	
	return closestTarget
end

local function startAimbot()
	if aimbotConnection then aimbotConnection:Disconnect() end
	createFOVCircle()
	
	aimbotConnection = RunService.RenderStepped:Connect(function()
		if not aimbotActive then
			if fovCircle then fovCircle.Visible = false end
			return
		end
		
		if fovCircle then
			fovCircle.Visible = true
			fovCircle.Size = UDim2.new(0, fovSize * 2, 0, fovSize * 2)
			fovCircle.Position = UDim2.new(0.5, -fovSize, 0.5, -fovSize)
		end
		
		local target = getClosestTarget()
		if target then
			local targetPosition = target.Position + Vector3.new(0, 2, 0)
			camera.CFrame = CFrame.lookAt(camera.CFrame.Position, targetPosition)
		end
	end)
end

local function createESPLine(targetPlayer)
	if espObjects[targetPlayer] then return end
	
	local espData = {
		line = Instance.new("Frame"),
		text = Instance.new("TextLabel")
	}
	
	espData.line.Name = "ESPLine"
	espData.line.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
	espData.line.BorderSizePixel = 0
	espData.line.Visible = false
	espData.line.Parent = gui
	
	espData.text.Name = "ESPText"
	espData.text.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	espData.text.BackgroundTransparency = 0.3
	espData.text.Text = targetPlayer.Name
	espData.text.TextColor3 = Color3.fromRGB(255, 255, 255)
	espData.text.Font = Enum.Font.GothamBold
	espData.text.TextSize = 14
	espData.text.Size = UDim2.new(0, 100, 0, 20)
	espData.text.Visible = false
	style(espData.text, 4)
	espData.text.Parent = gui
	
	espObjects[targetPlayer] = espData
end

local function updateESP()
	if not espActive then
		for _, data in pairs(espObjects) do
			if data.line then data.line:Destroy() end
			if data.text then data.text:Destroy() end
		end
		espObjects = {}
		return
	end
	
	for _, otherPlayer in ipairs(Players:GetPlayers()) do
		if otherPlayer ~= player and not espObjects[otherPlayer] then
			createESPLine(otherPlayer)
		end
	end
	
	for otherPlayer, data in pairs(espObjects) do
		local otherChar = otherPlayer.Character
		if otherChar then
			local otherRoot = otherChar:FindFirstChild("HumanoidRootPart")
			local otherHumanoid = otherChar:FindFirstChildOfClass("Humanoid")
			
			if otherRoot and otherHumanoid and otherHumanoid.Health > 0 then
				local character = player.Character
				if character then
					local rootPart = character:FindFirstChild("HumanoidRootPart")
					if rootPart then
						local screenPos, onScreen = camera:WorldToViewportPoint(otherRoot.Position)
						
						if onScreen then
							local center = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
							local targetPos = Vector2.new(screenPos.X, screenPos.Y)
							
							data.line.Visible = true
							data.line.Size = UDim2.new(0, (targetPos - center).Magnitude, 0, 2)
							data.line.Position = UDim2.new(0, center.X, 0, center.Y)
							data.line.Rotation = math.deg(math.atan2(targetPos.Y - center.Y, targetPos.X - center.X))
						end
					end
				end
			end
		end
	end
end
