tabList.BackgroundTransparency = 1
tabList.Parent = tabBar

local tabs = {}
local currentTab = "PRINCIPAL"

-- Função para criar aba
local function createTab(name, icon, position)
	local tabBtn = Instance.new("TextButton")
	tabBtn.Size = UDim2.new(0, 100, 0, 35)
	tabBtn.Position = UDim2.new(0, position, 0, 7)
	tabBtn.BackgroundTransparency = 1
	tabBtn.Text = ""
	tabBtn.Parent = tabList
	
	local tabIcon = Instance.new("ImageLabel")
	tabIcon.Size = UDim2.new(0, 20, 0, 20)
	tabIcon.Position = UDim2.new(0, 15, 0.5, -10)
	tabIcon.BackgroundTransparency = 1
	tabIcon.Image = icon
	tabIcon.ImageColor3 = Color3.fromRGB(150, 150, 150)
	tabIcon.Parent = tabBtn
	
	local tabText = Instance.new("TextLabel")
	tabText.Size = UDim2.new(1, -45, 1, 0)
	tabText.Position = UDim2.new(0, 40, 0, 0)
	tabText.BackgroundTransparency = 1
	tabText.Text = name
	tabText.Font = Enum.Font.Gotham
	tabText.TextSize = 14
	tabText.TextColor3 = Color3.fromRGB(150, 150, 150)
	tabText.TextXAlignment = Enum.TextXAlignment.Left
	tabText.Parent = tabBtn
	
	local indicator = Instance.new("Frame")
	indicator.Size = UDim2.new(1, -20, 0, 2)
	indicator.Position = UDim2.new(0, 10, 1, -5)
	indicator.BackgroundColor3 = Color3.fromRGB(60, 120, 255)
	indicator.Visible = false
	style(indicator, 2)
	indicator.Parent = tabBtn
	
	tabs[name] = {
		button = tabBtn,
		icon = tabIcon,
		text = tabText,
		indicator = indicator
	}
	
	tabBtn.MouseButton1Click:Connect(function()
		for _, tab in pairs(tabs) do
			tab.icon.ImageColor3 = Color3.fromRGB(150, 150, 150)
			tab.text.TextColor3 = Color3.fromRGB(150, 150, 150)
			tab.indicator.Visible = false
		end
		
		tabIcon.ImageColor3 = Color3.fromRGB(60, 120, 255)
		tabText.TextColor3 = Color3.fromRGB(255, 255, 255)
		indicator.Visible = true
		
		currentTab = name
		updateTabContent(name)
	end)
	
	return #tabs
end

