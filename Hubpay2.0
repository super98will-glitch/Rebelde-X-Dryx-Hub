contentArea.Position = UDim2.new(0, 20, 0, 120)
contentArea.BackgroundTransparency = 1
contentArea.Parent = hub

local contentPages = {}

-- Função para criar página de conteúdo
local function createPage(name)
	local page = Instance.new("ScrollingFrame")
	page.Size = UDim2.new(1, 0, 1, 0)
	page.BackgroundTransparency = 1
	page.ScrollBarThickness = 6
	page.ScrollBarImageColor3 = Color3.fromRGB(60, 120, 255)
	page.CanvasSize = UDim2.new(0, 0, 0, 0)
	page.AutomaticCanvasSize = Enum.AutomaticSize.Y
	page.Visible = false
	page.Parent = contentArea
	
	contentPages[name] = page
	return page
end

-- Função para atualizar aba visível
local function updateTabContent(tabName)
	for name, page in pairs(contentPages) do
		page.Visible = (name == tabName)
	end
end

