-- ===== SISTEMA CF SPEED =====
local function createSpeedIndicator()
	if speedIndicator then speedIndicator:Destroy() end
	
	speedIndicator = Instance.new("Frame")
	speedIndicator.Size = UDim2.new(0, 140, 0, 40)
	speedIndicator.Position = UDim2.new(0.5, -70, 0.9, 0)
	speedIndicator.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	speedIndicator.BackgroundTransparency = 0.3
	speedIndicator.BorderSizePixel = 0
	speedIndicator.Parent = player:WaitForChild("PlayerGui")
	style(speedIndicator, 8)
	addStroke(speedIndicator, 1, Color3.fromRGB(0, 255, 100), 0.5)
	
	local text = Instance.new("TextLabel")
	text.Size = UDim2.new(1, 0, 1, 0)
	text.BackgroundTransparency = 1
	text.Text = "⚡ " .. cfSpeedValue .. "x SPEED"
	text.Font = Enum.Font.GothamBold
	text.TextSize = 16
	text.TextColor3 = Color3.fromRGB(0, 255, 100)
	text.TextStrokeTransparency = 0.5
	text.Parent = speedIndicator
	
	createTween(speedIndicator, {Position = UDim2.new(0.5, -70, 0.85, 0)}, 0.5):Play()
end

local function updateSpeedIndicator()
	if speedIndicator then
		local text = speedIndicator:FindFirstChildOfClass("TextLabel")
		if text then
			text.Text = "⚡ " .. cfSpeedValue .. "x SPEED"
		end
	end
end

local function startCFSpeed()
	if cfConnection then cfConnection:Disconnect() end
	
	cfConnection = RunService.Heartbeat:Connect(function()
		if not cfSpeedActive then return end
		
		local character = player.Character
		if not character then
			character = player.CharacterAdded:Wait()
		end
		
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		local rootPart = character:FindFirstChild("HumanoidRootPart")
		
		if not humanoid or not rootPart or humanoid.Health <= 0 then return end
		
		local camera = Workspace.CurrentCamera
		local moveDirection = Vector3.new()
		
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then
			moveDirection = moveDirection + camera.CFrame.LookVector * Vector3.new(1, 0, 1)
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then
			moveDirection = moveDirection - camera.CFrame.LookVector * Vector3.new(1, 0, 1)
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then
			moveDirection = moveDirection - camera.CFrame.RightVector * Vector3.new(1, 0, 1)
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then
			moveDirection = moveDirection + camera.CFrame.RightVector * Vector3.new(1, 0, 1)
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
			moveDirection = moveDirection + Vector3.new(0, 1, 0)
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
			moveDirection = moveDirection - Vector3.new(0, 1, 0)
		end
		
		if moveDirection.Magnitude > 0 then
			moveDirection = moveDirection.Unit
			rootPart.CFrame = rootPart.CFrame + (moveDirection * cfSpeedValue * 0.5)
		end
	end)
end

